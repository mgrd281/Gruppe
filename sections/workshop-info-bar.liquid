{{-
  Workshop Info Bar Section
  Location and Duration information below gallery
-}}

{%- liquid
  assign location_note = product.metafields.custom.location_note | default: 'Details zur Location erhältst Du vom Veranstalter nach der Buchung'
  assign duration = product.metafields.custom.duration | default: '3h'
-%}

<div class="workshop-1-info-bar page-width">
  <div class="workshop-1-info-bar__container">
    
    <div class="workshop-1-info-bar__item">
      <svg class="workshop-1-info-bar__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>
      <span class="workshop-1-info-bar__text">{{ location_note }}</span>
    </div>
    
    <div class="workshop-1-info-bar__divider"></div>
    
    <div class="workshop-1-info-bar__item">
      <svg class="workshop-1-info-bar__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
      <span class="workshop-1-info-bar__text">Dauer: {{ duration }}</span>
    </div>
    
  </div>
</div>

<style>
.workshop-1-info-bar {
  padding-bottom: 2rem;
}

.workshop-1-info-bar__container {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.25rem;
  background: rgba(var(--color-foreground), 0.04);
  border-radius: 12px;
  flex-wrap: wrap;
}

.workshop-1-info-bar__item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.workshop-1-info-bar__icon {
  flex-shrink: 0;
  color: rgba(var(--color-foreground), 0.6);
}

.workshop-1-info-bar__text {
  font-size: 0.875rem;
  color: rgba(var(--color-foreground), 0.8);
}

.workshop-1-info-bar__divider {
  width: 1px;
  height: 20px;
  background: rgba(var(--color-foreground), 0.15);
}

@media screen and (max-width: 749px) {
  .workshop-1-info-bar__container {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }
  
  .workshop-1-info-bar__divider {
    display: none;
  }
}
</style>

{% schema %}
{
  "name": "Workshop Info Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "default_duration",
      "label": "Default Duration",
      "default": "3h"
    }
  ],
  "presets": [
    {
      "name": "Workshop Info Bar"
    }
  ]
}
{% endschema %}
