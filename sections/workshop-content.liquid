{% comment %}
  Workshop Content Section
  Two-column layout: Left content, Right sticky booking card
  Updated: 2024-02-24
{% endcomment %}

{%- liquid
  assign course_details = product.metafields.custom.course_details | default: product.description
  assign suitability = product.metafields.custom.suitability
  assign duration = product.metafields.custom.duration | default: '3h'
  assign location_note = product.metafields.custom.location_note | default: 'Details zur Location erhältst Du nach der Buchung'
  assign whats_included = product.metafields.custom.whats_included
  assign what_to_bring = product.metafields.custom.what_to_bring
  assign team_events = product.metafields.custom.team_events
  assign duration_details = product.metafields.custom.duration_details
  assign location_details = product.metafields.custom.location_details
  assign languages = product.metafields.custom.languages
  
  assign variant = product.selected_or_first_available_variant
  assign available_seats = variant.inventory_quantity | default: 0
  assign price = variant.price | money
-%}

<div class="workshop-1-content page-width">
  <div class="workshop-1-content__container">
    
    <!-- LEFT COLUMN -->
    <div class="workshop-1-content__left">
      
      <!-- About Course -->
      <div class="workshop-1-content__section">
        <h2 class="workshop-1-content__heading">Über diesen Kurs</h2>
        <div class="workshop-1-content__text">
          {{ course_details }}
        </div>
      </div>
      
      <!-- How it works -->
      <div class="workshop-1-content__section">
        <h2 class="workshop-1-content__heading">Wie läuft der Kurs ab?</h2>
        <ul class="workshop-1-content__list">
          <li>Einführung in die Grundlagen</li>
          <li>Praktische Übungen mit Anleitung</li>
          <li>Individuelle Betreuung</li>
          <li>Mitnehmen Deines fertigen Werks</li>
        </ul>
      </div>
      
      <!-- For whom -->
      {%- if suitability != blank -%}
        <div class="workshop-1-content__section">
          <h2 class="workshop-1-content__heading">Für wen ist der Kurs geeignet?</h2>
          <div class="workshop-1-content__text">
            {{ suitability }}
          </div>
        </div>
      {%- endif -%}
      
      <!-- Accordion -->
      <div class="workshop-1-content__section">
        <h2 class="workshop-1-content__heading">Wichtige Details</h2>
        
        <div class="workshop-1-accordion">
          
          {%- if what_to_bring != blank -%}
            <details class="workshop-1-accordion__item">
              <summary class="workshop-1-accordion__header">
                <svg class="workshop-1-accordion__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="16" y1="2" x2="16" y2="6"></line>
                  <line x1="8" y1="2" x2="8" y2="6"></line>
                  <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                <span>Was Du zum Kurs mitbringen solltest</span>
                <svg class="workshop-1-accordion__chevron" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div class="workshop-1-accordion__content">
                {{ what_to_bring }}
              </div>
            </details>
          {%- endif -%}
          
          {%- if whats_included != blank -%}
            <details class="workshop-1-accordion__item">
              <summary class="workshop-1-accordion__header">
                <svg class="workshop-1-accordion__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                </svg>
                <span>Was im Kurs inklusive ist</span>
                <svg class="workshop-1-accordion__chevron" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div class="workshop-1-accordion__content">
                {{ whats_included }}
              </div>
            </details>
          {%- endif -%}
          
          <details class="workshop-1-accordion__item">
            <summary class="workshop-1-accordion__header">
              <svg class="workshop-1-accordion__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              </svg>
              <span>Teamevents und Gruppen</span>
              <svg class="workshop-1-accordion__chevron" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </summary>
            <div class="workshop-1-accordion__content">
              <p>Perfekt für Firmenevents, Junggesellenabschiede oder private Gruppen. Kontaktiere uns für individuelle Termine.</p>
            </div>
          </details>
          
          <details class="workshop-1-accordion__item">
            <summary class="workshop-1-accordion__header">
              <svg class="workshop-1-accordion__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              <span>Dauer</span>
              <svg class="workshop-1-accordion__chevron" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </summary>
            <div class="workshop-1-accordion__content">
              <p>{{ duration }}</p>
            </div>
          </details>
          
          <details class="workshop-1-accordion__item">
            <summary class="workshop-1-accordion__header">
              <svg class="workshop-1-accordion__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <span>Standort</span>
              <svg class="workshop-1-accordion__chevron" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </summary>
            <div class="workshop-1-accordion__content">
              <p>{{ location_details | default: location_note }}</p>
            </div>
          </details>
          
          {%- if languages != blank -%}
            <details class="workshop-1-accordion__item">
              <summary class="workshop-1-accordion__header">
                <svg class="workshop-1-accordion__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
                  <line x1="4" y1="22" x2="4" y2="15"></line>
                </svg>
                <span>Sprachen</span>
                <svg class="workshop-1-accordion__chevron" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div class="workshop-1-accordion__content">
                {{ languages }}
              </div>
            </details>
          {%- endif -%}
          
        </div>
      </div>
      
    </div>
    
    <!-- RIGHT COLUMN - STICKY BOOKING CARD -->
    <div class="workshop-1-content__right">
      <div class="workshop-1-booking-card">
        
        <!-- Price -->
        <div class="workshop-1-booking-card__price-block">
          <span class="workshop-1-booking-card__price">{{ price }}</span>
          <span class="workshop-1-booking-card__per-ticket">Ab {{ price }} pro Ticket</span>
        </div>
        
        <!-- Booking Form -->
        <div class="workshop-1-booking-card__form">
          <p class="workshop-1-booking-card__label">Jetzt Tickets sichern</p>
          <p class="workshop-1-booking-card__sublabel">Teile uns die Anzahl der Teilnehmer mit</p>
          
          <!-- Quantity Selector -->
          <div class="workshop-1-booking-card__quantity">
            <button type="button" class="workshop-1-booking-card__qty-btn" data-qty-minus aria-label="Weniger">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </button>
            <input 
              type="number" 
              class="workshop-1-booking-card__qty-input" 
              value="1" 
              min="1" 
              max="{{ available_seats | at_least: 1 }}"
              data-qty-input
            >
            <button type="button" class="workshop-1-booking-card__qty-btn" data-qty-plus aria-label="Mehr">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </button>
          </div>
          
          <!-- Termin Dropdown -->
          <div class="workshop-1-booking-card__field">
            <label class="workshop-1-booking-card__field-label">Termin auswählen</label>
            <div class="workshop-1-booking-card__select-wrapper">
              <svg class="workshop-1-booking-card__select-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              <select class="workshop-1-booking-card__select" data-termin-select>
                {%- for tag in product.tags -%}
                  {%- if tag contains 'um' -%}
                    {%- assign parts = tag | split: ' um ' -%}
                    {%- assign tag_date = parts[0] -%}
                    {%- assign tag_time = parts[1] | split: ' ' | first -%}
                    <option value="{{ tag }}">Sa. {{ tag_date }}, {{ tag_time }} Uhr</option>
                  {%- endif -%}
                {%- endfor -%}
                {%- unless product.tags contains 'um' -%}
                  <option value="flexibel">Flexibler Termin</option>
                {%- endunless -%}
              </select>
              <svg class="workshop-1-booking-card__chevron" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </div>
          </div>
          
          <!-- Info Badge -->
          <div class="workshop-1-booking-card__badge">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
              <line x1="9" y1="9" x2="9.01" y2="9"></line>
              <line x1="15" y1="9" x2="15.01" y2="9"></line>
            </svg>
            <span>Du buchst die öffentliche Veranstaltung</span>
          </div>
          
          <!-- Add to Cart Button -->
          <button 
            type="button" 
            class="workshop-1-booking-card__cta"
            data-add-to-cart
            {% if available_seats <= 0 %}disabled{% endif %}
          >
            {%- if available_seats <= 0 -%}
              Ausgebucht
            {%- else -%}
              In den Warenkorb
            {%- endif -%}
          </button>
          
        </div>
        
        <!-- Gutschein Box -->
        <div class="workshop-1-booking-card__box">
          <h3 class="workshop-1-booking-card__box-title">Gutschein kaufen für {{ price }}</h3>
          <ul class="workshop-1-booking-card__box-list">
            <li>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              Ab Kauf 3 Jahre lang gültig
            </li>
            <li>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              Einlösbar für über 10.000 Erlebnisse
            </li>
            <li>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              Gutschein zum Selbstausdrucken
            </li>
          </ul>
          <button type="button" class="workshop-1-booking-card__box-btn" data-gutschein>
            Als Gutschein kaufen
          </button>
        </div>
        
        <!-- Teamevent Box -->
        <div class="workshop-1-booking-card__box workshop-1-booking-card__box--outline">
          <h3 class="workshop-1-booking-card__box-title">Teamevent anfragen</h3>
          <p class="workshop-1-booking-card__box-text">Individuelle Termine anfragen. Auch für Firmenevents oder private Gruppen. Unverbindliches Angebot erhalten.</p>
          <button type="button" class="workshop-1-booking-card__box-btn workshop-1-booking-card__box-btn--outline" data-teamevent onclick="document.getElementById('workshop-inquiry-modal').showModal()">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            </svg>
            Event anfragen >
          </button>
        </div>
        
        <!-- Inquiry Modal Form -->
        <dialog id="workshop-inquiry-modal" class="workshop-inquiry-modal">
          <div class="workshop-inquiry-modal__content">
            <button class="workshop-inquiry-modal__close" onclick="document.getElementById('workshop-inquiry-modal').close()" aria-label="Schließen">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
            
            <h2 class="workshop-inquiry-modal__title">Jetzt unverbindlich anfragen!</h2>
            
            <form class="workshop-inquiry-form" action="/contact" method="post">
              <input type="hidden" name="form_type" value="contact">
              <input type="hidden" name="utf8" value="✓">
              <input type="hidden" name="contact[subject]" value="Workshop Anfrage: {{ product.title | escape }}">
              
              <div class="workshop-inquiry-form__row">
                <div class="workshop-inquiry-form__field">
                  <label class="workshop-inquiry-form__label" for="inquiry-firstname">Vorname <span class="required">*</span></label>
                  <input type="text" id="inquiry-firstname" name="contact[first_name]" class="workshop-inquiry-form__input" placeholder="Erika" required>
                </div>
                <div class="workshop-inquiry-form__field">
                  <label class="workshop-inquiry-form__label" for="inquiry-lastname">Nachname <span class="required">*</span></label>
                  <input type="text" id="inquiry-lastname" name="contact[last_name]" class="workshop-inquiry-form__input" placeholder="Mustermann" required>
                </div>
              </div>
              
              <div class="workshop-inquiry-form__field">
                <label class="workshop-inquiry-form__label" for="inquiry-email">E-Mail <span class="required">*</span></label>
                <input type="email" id="inquiry-email" name="contact[email]" class="workshop-inquiry-form__input" placeholder="erika@mustermann.de" required>
              </div>
              
              <div class="workshop-inquiry-form__field">
                <label class="workshop-inquiry-form__label" for="inquiry-participants">Anzahl Teilnehmer <span class="required">*</span></label>
                <input type="number" id="inquiry-participants" name="contact[participants]" class="workshop-inquiry-form__input" placeholder="Personenanzahl" min="1" required>
              </div>
              
              <div class="workshop-inquiry-form__field">
                <label class="workshop-inquiry-form__label" for="inquiry-phone">Telefon für Rückfragen <span class="required">*</span></label>
                <input type="tel" id="inquiry-phone" name="contact[phone]" class="workshop-inquiry-form__input" placeholder="+49 123 456 789" required>
                <span class="workshop-inquiry-form__hint">Telefonisch lässt sich Dein Event erfahrungsgemäß am schnellsten absprechen!</span>
              </div>
              
              <div class="workshop-inquiry-form__field">
                <label class="workshop-inquiry-form__label" for="inquiry-company">Unternehmensname</label>
                <input type="text" id="inquiry-company" name="contact[company]" class="workshop-inquiry-form__input" placeholder="">
                <span class="workshop-inquiry-form__hint">Natürlich nur, wenn es sich um eine Firmenanfrage dreht.</span>
              </div>
              
              <div class="workshop-inquiry-form__field">
                <label class="workshop-inquiry-form__label" for="inquiry-city">Stadt</label>
                <input type="text" id="inquiry-city" name="contact[city]" class="workshop-inquiry-form__input" placeholder="">
                <span class="workshop-inquiry-form__hint">Wo soll es stattfinden?</span>
              </div>
              
              <div class="workshop-inquiry-form__field">
                <label class="workshop-inquiry-form__label" for="inquiry-date">Termin auswählen</label>
                <div class="workshop-inquiry-form__date-wrapper">
                  <svg class="workshop-inquiry-form__date-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  <input type="text" id="inquiry-date" name="contact[preferred_date]" class="workshop-inquiry-form__input workshop-inquiry-form__input--date" placeholder="Termin auswählen">
                </div>
                <span class="workshop-inquiry-form__hint">Sofern Du mehrere mögliche Daten hast, gib einfach das an, welches Euch am liebsten ist.</span>
              </div>
              
              <div class="workshop-inquiry-form__checkbox">
                <input type="checkbox" id="inquiry-consent" name="contact[consent]" required>
                <label for="inquiry-consent">Mit klicken auf "Abschicken", stimmst Du zu, dass wir Dich kontaktieren.</label>
              </div>
              
              <button type="submit" class="workshop-inquiry-form__submit">Abschicken</button>
            </form>
          </div>
        </dialog>
        
      </div>
    </div>
    
  </div>
</div>

<style>
.workshop-1-content {
  padding-bottom: 4rem;
}

.workshop-1-content__container {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
}

/* LEFT COLUMN */
.workshop-1-content__section {
  margin-bottom: 2.5rem;
}

.workshop-1-content__heading {
  font-size: 1.5rem;
  font-weight: 600;
  color: rgb(var(--color-foreground));
  margin: 0 0 1rem;
}

.workshop-1-content__text {
  font-size: 1rem;
  line-height: 1.6;
  color: rgba(var(--color-foreground), 0.8);
}

.workshop-1-content__text p {
  margin: 0 0 1rem;
}

.workshop-1-content__list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.workshop-1-content__list li {
  position: relative;
  padding-left: 1.25rem;
  margin-bottom: 0.75rem;
  font-size: 1rem;
  line-height: 1.5;
  color: rgba(var(--color-foreground), 0.8);
}

.workshop-1-content__list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.5rem;
  width: 6px;
  height: 6px;
  background: rgb(var(--color-foreground));
  border-radius: 50%;
}

/* Accordion */
.workshop-1-accordion {
  border: 1px solid rgba(var(--color-foreground), 0.1);
  border-radius: 12px;
  overflow: hidden;
}

.workshop-1-accordion__item {
  border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
}

.workshop-1-accordion__item:last-child {
  border-bottom: none;
}

.workshop-1-accordion__header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 1.25rem;
  cursor: pointer;
  font-size: 0.9375rem;
  font-weight: 500;
  color: rgb(var(--color-foreground));
  list-style: none;
  transition: background 150ms ease;
}

.workshop-1-accordion__header:hover {
  background: rgba(var(--color-foreground), 0.02);
}

.workshop-1-accordion__header::-webkit-details-marker {
  display: none;
}

.workshop-1-accordion__icon {
  flex-shrink: 0;
  color: rgba(var(--color-foreground), 0.5);
}

.workshop-1-accordion__chevron {
  margin-left: auto;
  flex-shrink: 0;
  color: rgba(var(--color-foreground), 0.5);
  transition: transform 200ms ease;
}

.workshop-1-accordion__item[open] .workshop-1-accordion__chevron {
  transform: rotate(180deg);
}

.workshop-1-accordion__content {
  padding: 0 1.25rem 1rem 3rem;
  font-size: 0.9375rem;
  line-height: 1.6;
  color: rgba(var(--color-foreground), 0.75);
  animation: workshopAccordionOpen 200ms ease;
}

@keyframes workshopAccordionOpen {
  from {
    opacity: 0;
    transform: translateY(-4px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* RIGHT COLUMN - BOOKING CARD */
.workshop-1-content__right {
  order: -1;
}

.workshop-1-booking-card {
  background: #fff;
  border: 1px solid rgba(var(--color-foreground), 0.1);
  border-radius: 16px;
  padding: 1.5rem;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
}

.workshop-1-booking-card__price-block {
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
}

.workshop-1-booking-card__price {
  display: block;
  font-size: 1.75rem;
  font-weight: 700;
  color: rgb(var(--color-foreground));
}

.workshop-1-booking-card__per-ticket {
