{% comment %}
  Editorial product gallery for Workshop template.
  Hero + 2-column grid layout (AboutYou-style).
  Supports: images, videos, external videos (YouTube/Vimeo).
  Premium zoom: hover scale + fullscreen lightbox.
{% endcomment %}

{%- liquid
  assign first_media = product.featured_media
  assign media_count = product.media.size
-%}

<div class="workshop-gallery" data-workshop-gallery data-product-id="{{ product.id }}">
  
  {%- if media_count > 0 -%}
    
    <!-- Hero Media -->
    <div class="workshop-gallery__hero">
      {%- if first_media -%}
        <div 
          class="workshop-gallery__hero-media workshop-gallery__zoomable" 
          data-media-type="{{ first_media.media_type }}"
          data-media-id="{{ first_media.id }}"
          data-media-index="0"
          tabindex="0"
          role="button"
          aria-label="Open fullscreen gallery"
        >
          {%- case first_media.media_type -%}
            
            {%- when 'image' -%}
              {{
                first_media
                | image_url: width: 1400
                | image_tag:
                  loading: 'eager',
                  sizes: '(min-width: 990px) 55vw, 100vw',
                  widths: '550, 720, 990, 1100, 1400',
                  alt: first_media.alt | default: product.title,
                  class: 'workshop-gallery__zoom-img'
              }}
              
              <!-- Zoom Icon -->
              <div class="workshop-gallery__zoom-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                  <line x1="11" y1="8" x2="11" y2="14"></line>
                  <line x1="8" y1="11" x2="14" y2="11"></line>
                </svg>
                <span class="workshop-gallery__zoom-text">Zoom</span>
              </div>
            
            {%- when 'video' -%}
              <div class="workshop-gallery__video-wrapper">
                {{ first_media | media_tag: controls: true, autoplay: false, loop: false, playsinline: true, preload: 'metadata' }}
              </div>
            
            {%- when 'external_video' -%}
              <div class="workshop-gallery__video-wrapper external-video">
                {{ first_media | media_tag: controls: true, autoplay: false, loop: false, playsinline: true }}
              </div>
            
            {%- when 'model' -%}
              {{ first_media | model_viewer_tag }}
            
          {%- endcase -%}
        </div>
      {%- endif -%}
    </div>
    
    <!-- Grid (remaining media, 2-column) -->
    {%- if media_count > 1 -%}
      <div class="workshop-gallery__grid">
        {%- for media in product.media offset: 1 -%}
          {%- assign media_index = forloop.index -%}
          <div 
            class="workshop-gallery__grid-item workshop-gallery__zoomable{% if media.media_type == 'image' %} workshop-gallery__zoomable--image{% endif %}" 
            data-media-type="{{ media.media_type }}"
            data-media-id="{{ media.id }}"
            data-media-index="{{ media_index }}"
            tabindex="0"
            role="button"
            aria-label="Open fullscreen gallery"
          >
            {%- case media.media_type -%}
              
              {%- when 'image' -%}
                {{
                  media
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 990px) calc((55vw - 20px) / 2), 100vw',
                    widths: '400, 550, 720, 800',
                    alt: media.alt | default: product.title,
                    class: 'workshop-gallery__zoom-img'
                }}
                
                <!-- Zoom Icon (mobile always visible, desktop on hover) -->
                <div class="workshop-gallery__zoom-icon workshop-gallery__zoom-icon--grid" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    <line x1="11" y1="8" x2="11" y2="14"></line>
                    <line x1="8" y1="11" x2="14" y2="11"></line>
                  </svg>
                </div>
              
              {%- when 'video' -%}
                <div class="workshop-gallery__video-wrapper">
                  {{ media | media_tag: controls: true, autoplay: false, loop: false, playsinline: true, preload: 'metadata' }}
                </div>
              
              {%- when 'external_video' -%}
                <div class="workshop-gallery__video-wrapper external-video">
                  {{ media | media_tag: controls: true, autoplay: false, loop: false, playsinline: true }}
                </div>
              
              {%- when 'model' -%}
                <div class="workshop-gallery__model-wrapper">
                  {{ media | model_viewer_tag }}
                </div>
              
            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
    
  {%- else -%}
    
    <!-- Placeholder if no media -->
    <div class="workshop-gallery__hero">
      <div class="workshop-gallery__hero-image workshop-gallery__placeholder">
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    </div>
    
  {%- endif -%}
  
</div>

<!-- Lightbox Modal -->
<div id="workshop-lightbox" class="workshop-lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Fullscreen gallery">
  <div class="workshop-lightbox__overlay"></div>
  
  <button class="workshop-lightbox__close" aria-label="Close gallery">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  
  <button class="workshop-lightbox__nav workshop-lightbox__nav--prev" aria-label="Previous image">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  
  <button class="workshop-lightbox__nav workshop-lightbox__nav--next" aria-label="Next image">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>
  
  <div class="workshop-lightbox__content">
    <div class="workshop-lightbox__media-container" data-lightbox-media>
      <!-- Media loaded dynamically via JS -->
    </div>
    <div class="workshop-lightbox__counter">
      <span data-lightbox-current>1</span> / <span data-lightbox-total>{{ media_count }}</span>
    </div>
  </div>
</div>

<script src="{{ 'workshop-gallery-zoom.js' | asset_url }}" defer></script>
